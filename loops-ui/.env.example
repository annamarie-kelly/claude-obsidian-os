# Copy this file to `.env.local` and fill in any overrides you need.
# All variables are optional; the app has sensible defaults.

# Absolute path to the Obsidian vault the app should read. Defaults to
# the sibling `../vault-template/` directory (the scaffolding that
# ships with this repo). Point this at your own vault once you're
# ready to use it against real data.
# LOOPS_UI_VAULT_ROOT=/Users/you/obsidian-vault

# The vault folder name Obsidian uses to identify itself in `obsidian://`
# URLs. Check the sidebar in Obsidian → the vault name at the top. If
# your vault folder and vault name differ, set this explicitly so
# "Open in Obsidian" links from the detail drawer work.
# NEXT_PUBLIC_OBSIDIAN_VAULT=your-vault-name
