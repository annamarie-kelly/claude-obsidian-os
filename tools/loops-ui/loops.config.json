{
  "$schema": "./loops.config.schema.json",
  "vault": {
    "scanFolders": [
      "00-Inbox",
      "01-Building",
      "02-Thinking",
      "03-Working",
      "04-Living",
      "05-Relating"
    ],
    "inboxFile": "00-Inbox/manual-loops.md",
    "adoptedFile": "00-Inbox/adopted.md",
    "closeOutsFile": "00-Inbox/close-outs.md"
  },
  "stakeholder": {
    "name": "Stakeholder",
    "tag": "Stakeholder",
    "capacityMax": 8,
    "weeklySummary": true,
    "staleDays": 5
  },
  "self": {
    "capacityMax": 5
  },
  "priorityCaps": {
    "P1Flat": 8,
    "P2Flat": 20
  },
  "scannerStakeholders": [],
  "subgroupHints": [
    { "match": "sanity",  "mode": "design" },
    { "match": "pattern", "mode": "design" },
    { "match": "review",  "mode": "communicate" },
    { "match": "schedule", "mode": "communicate" }
  ]
}
